{
  "authKit": {
    "dev": {
      "configure": {
        "redirectUris": ["http://localhost:5173/callback"],
        "appHomepageUrl": "http://localhost:5173",
        "corsOrigins": ["http://localhost:5173"]
      },
      "localEnvVars": {
        "VITE_WORKOS_CLIENT_ID": "${authEnv.WORKOS_CLIENT_ID}",
        "VITE_WORKOS_REDIRECT_URI": "http://localhost:5173/callback"
      }
    },
    "prod": {
      "configure": {
        "redirectUris": ["https://your-production-domain.com/callback"],
        "appHomepageUrl": "https://your-production-domain.com",
        "corsOrigins": ["https://your-production-domain.com"]
      }
    }
  }
}
