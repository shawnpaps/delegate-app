# Backend email service (Hono + Node.js)
FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY backend/package.json backend/package-lock.json* backend/pnpm-lock.yaml* ./

# Install dependencies
RUN npm install

# Copy source code
COPY backend/ ./

# Build TypeScript to JavaScript
RUN npm run build

# Expose the port
EXPOSE 3001

# Run the compiled JavaScript
CMD ["npm", "start"]
