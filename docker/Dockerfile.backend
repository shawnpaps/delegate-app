# Backend email service (Hono + Node.js)
FROM node:22-alpine

WORKDIR /app

# Copy package.json only (no lock files since backend uses plain npm)
COPY backend/package.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY backend/src ./src/
COPY backend/tsconfig.json ./

# Build TypeScript to JavaScript
RUN npm run build

# Expose the port
EXPOSE 3001

# Run the compiled JavaScript
CMD ["npm", "start"]
