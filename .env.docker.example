# Docker Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Frontend Configuration
# ============================================

# Backend URL (must be accessible from browser)
# For VPS deployment, use your domain or IP
VITE_BACKEND_URL=http://localhost:3001

# Convex Configuration (Cloud service - get from Convex dashboard)
VITE_CONVEX_URL=https://your-deployment.convex.site

# WorkOS Auth Configuration (get from WorkOS dashboard)
VITE_WORKOS_CLIENT_ID=client_xxxxxxxxxx
VITE_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================
# Backend Configuration
# ============================================

# Mailgun Configuration (get from Mailgun dashboard)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.yourdomain.com

# Convex Admin Configuration (get from Convex dashboard settings)
CONVEX_HTTP_URL=https://your-deployment.convex.site
CONVEX_ADMIN_KEY=your_convex_admin_key_here

# Backend URL (for Convex webhooks to reach your backend)
# For VPS deployment, use your domain or IP
BACKEND_URL=http://localhost:3001
